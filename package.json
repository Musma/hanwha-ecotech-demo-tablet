{
  "name": "hanwha",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 4000",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4000",
    "lint": "eslint \"**/*.{ts,vue}\" --fix",
    "lint:staged": "lint-staged",
    "type-check": "vue-tsc --noEmit",
    "check:tokens": "node scripts/design-tokens/check-tokens.mjs",
    "design:qa": "pnpm build && pnpm check:tokens",
    "tokens:codemod": "node scripts/design-tokens/codemod.mjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,vue}": "eslint --fix",
    "*.{ts,vue}": "node scripts/design-tokens/check-tokens.mjs",
    "*.{css,scss,html,json,md,yml,yaml}": "prettier --write"
  },
  "packageManager": "pnpm@9.1.2",
  "dependencies": {
    "@internationalized/date": "^3.12.2",
    "@lucide/vue": "^1.20.0",
    "@tabler/icons-webfont": "^3.44.0",
    "@tailwindcss/vite": "^4.3.1",
    "@vueuse/core": "^14.3.0",
    "axios": "^1.18.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "maplibre-gl": "4.7.1",
    "pinia": "^3.0.4",
    "reka-ui": "^2.9.10",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-router": "4",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@musma/eslint-config-vue": "^1.0.1",
    "@types/node": "^25.9.3",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  }
}
